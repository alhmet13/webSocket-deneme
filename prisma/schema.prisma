generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model device {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  light      Boolean
  deviceName String
  createdAt  DateTime @default(now())
}
